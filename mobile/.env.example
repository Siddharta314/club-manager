# Clerk publishable key. Get this from the Clerk dashboard:
#   https://dashboard.clerk.com → API Keys → Publishable key
# Format: pk_test_* for development, pk_live_* for production.
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Backend base URL. Default points at a local Django on port 8000.
# If testing on a physical device, replace with your machine's LAN IP, e.g.
#   http://192.168.1.42:8000/api/v1
EXPO_PUBLIC_API_URL=http://localhost:8000/api/v1
