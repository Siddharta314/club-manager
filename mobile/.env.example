# Clerk publishable key. Get this from the Clerk dashboard:
#   https://dashboard.clerk.com → API Keys → Publishable key
# Format: pk_test_* for development, pk_live_* for production.
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Backend base URL.
# - In-container (docker compose): http://web:8000/api/v1  ← default
# - Bare-host dev (pnpm start on laptop): http://localhost:8000/api/v1
# - Physical device: http://<your-LAN-IP>:8000/api/v1
EXPO_PUBLIC_API_URL=http://web:8000/api/v1
