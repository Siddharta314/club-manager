# Application
DJANGO_SETTINGS_MODULE=padel.settings
DEBUG=true
SECRET_KEY=dev-insecure-secret-key-do-not-use-in-production
MVP_ENABLED=true

# Database — matches docker-compose.yml Postgres service (padel:padel/padel)
# so `docker compose up` connects with no .env edits. We use host port
# 5433 (instead of the Postgres default 5432) to avoid colliding with
# any local Postgres install a developer may already be running.
DATABASE_URL=postgresql://padel:padel@localhost:5433/padel

# Hosts / CORS
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,web,172.17.0.1
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://127.0.0.1:8081,http://localhost:19006
TIME_ZONE=Europe/Madrid

# Media
MEDIA_ROOT=./media
MEDIA_URL=/media/

# Clerk (PR 2) — fill in real values from your Clerk dashboard.
# Leave empty in CI / unit-test runs.
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
# Optional symmetric secret for offline JWT verification (skips JWKS fetch).
# If left empty, ClerkJWTMiddleware fetches keys from CLERK_JWKS_URL.
CLERK_JWT_KEY=
CLERK_JWKS_URL=
CLERK_WEBHOOK_SECRET=
# Optional: list of audiences to accept (comma-separated). Empty = any.
CLERK_JWT_AUDIENCE=

# Notifications (PR 4)
RESEND_API_KEY=
EXPO_ACCESS_TOKEN=
