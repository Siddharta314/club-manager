# Application
DJANGO_SETTINGS_MODULE=padel.settings
DEBUG=true
SECRET_KEY=dev-insecure-secret-key-do-not-use-in-production
MVP_ENABLED=true

# Database
DATABASE_URL=postgres://padel:padel@db:5432/padel

# Hosts / CORS
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://127.0.0.1:8081
TIME_ZONE=Europe/Madrid

# Media
MEDIA_ROOT=/app/media
MEDIA_URL=/media/

# Clerk (PR 2)
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_JWKS_URL=
CLERK_WEBHOOK_SECRET=

# Notifications (PR 4)
RESEND_API_KEY=
EXPO_ACCESS_TOKEN=